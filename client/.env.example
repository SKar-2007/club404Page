# Piston API — proxied through Vercel serverless function at /api/piston/execute
VITE_PISTON_EXEC_URL=/api/piston/execute

# Supabase — replace with your project credentials
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Hall of Fame API
VITE_HOF_API_URL=https://jsonbinzeta.vercel.app/api/bins
VITE_HOF_PROJECTS_BIN_ID=your-projects-bin-id
VITE_HOF_ACHIEVEMENTS_BIN_ID=your-achievements-bin-id
VITE_HOF_LEADERBOARD_BIN_ID=your-leaderboard-bin-id

# Social Links
VITE_WHATSAPP_LINK=https://chat.whatsapp.com/your-invite-link
VITE_DISCORD_LINK=https://discord.gg/your-invite-link
